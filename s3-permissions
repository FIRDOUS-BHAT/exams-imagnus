{
	"Version": "2012-10-17",
	"Statement": [
		{
			"Sid": "PublicRead",
			"Effect": "Allow",
			"Principal": "*",
			"Action": [
				"s3:GetObject",
				"s3:GetObjectVersion"
			],
			"Resource": "arn:aws:s3:::testing-bucket-s3-uploader/*"
		}
	]
}

{
	"Version": "2012-10-17",
	"Id": "AllowSpecificDomain",
	"Statement": [
		{
			"Sid": "AllowGetRequests",
			"Effect": "Allow",
			"Principal": "*",
			"Action": [
				"s3:GetObject",
				"s3:GetObjectVersion"
			],
			"Resource": "arn:aws:s3:::testing-bucket-s3-uploader/*",
			"Condition": {
				"StringLike": {
					"aws:Referer": "https://exams.imagnus.in/*"
				}
			}
		}
	]
}
