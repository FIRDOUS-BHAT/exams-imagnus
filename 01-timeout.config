files:
  "/etc/nginx/conf.d/01-timeout.conf":
    mode: "000644"
    owner: root
    group: root
    content: |
      keepalive_timeout 120s;
      proxy_connect_timeout 120s;
      proxy_send_timeout 1200;
      proxy_read_timeout 1200;
      send_timeout       1200;
container_commands:
  nginx_reload:
     command: “sudo service nginx reload”