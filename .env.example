# ==============================================================================
# I-MAGNUS EXAM PLATFORM - DEPLOYMENT ENVIRONMENT TEMPLATE
# ==============================================================================
# Copy this file to .env and fill in the values for your production environment.
# Values marked as [REQUIRED] must be provided for the app to function.

# --- Core App Settings ---
APP_NAME="I-Magnus Exams"
APP_VERSION="1.0.0"
APP_FRAMEWORK="FastAPI"
DEBUG=False
APP_TYPE="production"
ALLOWED_HOST="*"
APP_URL="https://your-app-name.onrender.com"

# --- Database (Recommended: Neon.tech or Supabase) ---
DB_CONNECTION=postgres
DB_HOST=your-db-host.example.com
DB_PORT=5432
DB_DATABASE=your-db-name
DB_USERNAME=your-db-user
DB_PASSWORD=your-secure-password
DB_SSLMODE=require

# --- Security ---
SECRET_KEY=generate-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
COOKIE_NAME=imagnus_session
ADMIN_LOGIN=admin_session

# --- Redis (Recommended: Upstash.com) ---
REDIS_URL=redis://default:your-password@your-redis-host.example.com:6379
CACHE_TIME=3600

# --- AWS / S3 Settings (Storage for Notes/Videos) ---
AWS_SERVER_PUBLIC_KEY=your-aws-access-key
AWS_SERVER_SECRET_KEY=your-aws-secret-key
AWS_SERVER_REGION=ap-south-1
IMAGEKIT_PRIVATE_KEY=your-imagekit-private-key
IMAGEKIT_PUBLIC_KEY=your-imagekit-public-key
BUNNY_LIBRARY_ID=your-bunny-library-id
BUNNY_CDN_HOST=your-bunny-cdn-host
BUNNY_ACCESS_KEY=your-bunny-access-key

# --- Payment Gateways ---
RAZORPAY_KEY=your-razorpay-key-id
RAZORPAY_SECRET=your-razorpay-secret

# --- External Integration ---
SLACK_WEBHOOK_URL=
SMS_API_KEY=your-sms-gateway-key
FCM_SERVER_KEY=your-fcm-server-key
VIMEO_CLIENT_ID=your-vimeo-client-id
VIMEO_CLIENT_SECRET=your-vimeo-client-secret
VIMEO_ACCESS_TOKEN=your-vimeo-access-token
LEGACY_API_USERNAME=your-internal-api-username
LEGACY_API_PASSWORD=your-internal-api-password
WS_URL=wss://your-app-name.onrender.com

# --- Firebase Web Analytics (public browser config, restrict in Google Cloud) ---
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-firebase-app-id
FIREBASE_MEASUREMENT_ID=your-measurement-id

# --- Mail Server ---
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password
MAIL_FROM=info@imagnus.in
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_FROM_NAME="I-Magnus Academy"
